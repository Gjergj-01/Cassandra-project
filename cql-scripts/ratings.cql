VALUES ('s481', 'TV-14', 'Movie', 'Finding Hubby', '105 min', 'Oyin and her two close friends are on the hunt for husbands, but find that they must grapple with their own expectations as they look for love.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s482', 'TV-MA', 'Movie', 'How I Became a Superhero', '101 min', 'In a world where humans and superheroes coexist, a lone wolf cop teams up with a bright detective to dismantle a dark plot to extract superpowers.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s483', 'TV-MA', 'TV Show', 'How to Become a Tyrant', '1 Season', 'Ruling with an iron fist requires an aspiring dictator to know the playbook for absolute power, as history''s despots prove in this sardonic docuseries.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s484', 'TV-MA', 'Movie', 'Last Summer', '102 min', 'During summer vacation in a beachside town, 16-year-old Deniz seeks the affection of his childhood crush and navigates a love triangle.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s485', 'TV-G', 'Movie', 'Lee Su-geun: The Sense Coach', '46 min', 'Lee Su-geun''s rise to Korean comedy stardom went hand in hand with his mastery over picking up social cues. Now, he''s ready to share his know-hows.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s486', 'TV-14', 'Movie', 'Lethal Love', '89 min', 'After a business owner starts receiving online threats, doubts and paranoia creep in when she reconnects with a former flame and meets a new client.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s487', 'PG', 'Movie', 'Ratchet and Clank', '94 min', 'Affable alien Ratchet longs to be a Galactic Ranger and might get the chance when rogue robot Clank tells him of evil Drek''s plot to destroy a galaxy.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s488', 'TV-MA', 'TV Show', 'The Cook of Castamar', '1 Season', 'In 1720 Madrid, a talented cook catches the eye of a widowed duke just as he returns to aristocratic society. Based on the novel by Fernando J. Munez.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s489', 'TV-14', 'TV Show', 'Virgin River', '3 Seasons', 'Searching for a fresh start, a nurse practitioner moves from LA to a remote northern California town and is surprised by what  and who  she finds.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s490', 'TV-14', 'Movie', 'Back to Q82', '104 min', 'Eager to rejoin her divorced parents, an inventor''s daughter drives his time-traveling car back to 1982. But a secret crush accidentally follows.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s491', 'TV-MA', 'TV Show', 'Elize Matsunaga: Once Upon a Crime', '1 Season', 'The crime shocked Brazil: Elize Matsunaga shot and dismembered her rich husband. Featuring her first interview, this docuseries dives deep into the case.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s492', 'PG-13', 'Movie', 'Home Again', '97 min', 'A newly single mom takes in three young male filmmakers as boarders, but her estranged husband returns to complicate her new, unconventional life.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s493', 'PG-13', 'Movie', 'Midnight Sun', '91 min', 'Born with a fatal sensitivity to sunlight, a sheltered teen girl falls for her neighbor, but hides her condition from him as their romance blossoms.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s494', 'TV-MA', 'TV Show', 'RESIDENT EVIL: Infinite Darkness', '1 Season', 'Years after the horrors of Raccoon City, Leon and Claire find themselves consumed by a dark conspiracy when a viral attack ravages the White House.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s495', 'R', 'Movie', 'Rock the Kasbah', '106 min', 'When a has-been music producer gets stuck in Afghanistan he discovers a girl with a wonderful voice, then has to find a way to market her talents.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s496', 'TV-MA', 'Movie', 'Awon Boyz', '38 min', 'This documentary takes a close look at the lives and passions of the men and boys who hustle or run with a gang on the streets of Lagos.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s497', 'PG-13', 'Movie', 'Brick Mansions', '90 min', 'An undercover police detective partners with an ex-convict to take down a drug kingpin amid grime and crime in a walled-off Detroit housing project.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s498', 'TV-14', 'TV Show', 'Cat People', '1 Season', 'Cat people come in all shapes and sizes, but they share a love for their enchanting, unique feline friends. This docuseries reveals their tales.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s499', 'TV-MA', 'Movie', 'Clash', '87 min', 'When the patriarch of an emigrant Nigerian family visits their female-led Canadian home, traditional values collide with newer ones.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s500', 'TV-PG', 'TV Show', 'Dogs', '2 Seasons', 'These six intimate stories explore the abiding emotional bonds that form between dogs and their caregivers, no matter the circumstances.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s501', 'TV-MA', 'Movie', 'Major Grom: Plague Doctor', '138 min', 'When a masked vigilantes killing spree throws a city into chaos, a renegade detective and his rookie partner are the only ones who can stop it.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s502', 'TV-MA', 'Movie', 'Mama Drama', '105 min', 'After years of fertility issues and her mother-in-law''s nagging, a woman hires her assistant as a surrogate. But things dont go as smoothly as planned.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s503', 'TV-14', 'Movie', 'Tango With Me', '104 min', 'A newly married couple journeys through self-discovery and healing while dealing with the aftermath of a traumatic event on their wedding night.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s504', 'TV-MA', 'TV Show', 'The Mire', '2 Seasons', 'In an early-''80s Polish town, a prostitute and a youth leader are found killed, but the police''s handling of the case makes two journalists suspicious.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s505', 'TV-MA', 'TV Show', 'The War Next-door', '1 Season', 'When two antagonistic families end up living next door in a posh neighborhood, the matriarchs ensue a full-scale war of unintended consequences.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s506', 'TV-PG', 'Movie', 'Therapy', '85 min', 'A young dysfunctional couple tries to patch up their relationship through sessions with a highly unconventional therapist.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s507', 'TV-G', 'Movie', 'This Little Love Of Mine', '92 min', 'A workaholic lawyer returns to her island home to convince an old friend to take over his familys company  but rekindled feelings soon get in the way.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s508', 'TV-14', 'Movie', 'Three Thieves', '108 min', 'Frustrated at work, three young men use a case of mistaken identity to pull off a seemingly simple crime  but their scheme comically unravels.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s509', 'TV-MA', 'Movie', 'A Land Imagined', '95 min', 'A cop in Singapore investigates the disappearance of a Chinese migrant construction worker who spent sleepless nights playing a mysterious video game.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s510', 'TV-Y', 'TV Show', 'Ask the StoryBots', '3 Seasons', 'Five curious little creatures track down the answers to kids'' biggest questions, like how night happens or why we need to brush our teeth.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s511', 'TV-14', 'TV Show', 'Between', '2 Seasons', 'After a mysterious disease kills every resident over 22 years old, survivors of a town must fend for themselves when the government quarantines them.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s512', 'TV-MA', 'TV Show', 'Chelsea', '2 Seasons', 'It''s not her first talk show, but it is a first of its kind. Ideas, people and places that fascinate her, all in her unique style.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s513', 'TV-Y7', 'TV Show', 'Code Lyoko', '4 Seasons', 'After discovering a parallel universe hidden inside a supercomputer, four students must stop a renegade virus from destroying the secret world.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
