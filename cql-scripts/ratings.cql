INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s118', 'PG-13', 'Movie', 'Final Account', '94 min', 'This documentary stitches together never-before-seen interviews with the last living generation of people who participated in Hitler''s Third Reich.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
