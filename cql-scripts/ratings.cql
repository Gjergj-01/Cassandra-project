INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s64', 'TV-PG', 'Movie', 'Naruto the Movie: Ninja Clash in the Land of Snow', '83 min', 'Naruto, Sasuke and Sakura learn they''ll be protecting an actress from being hurt while making her next film, but it turns out she''s a princess.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
