INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s1', 'PG-13', 'Movie', 'Dick Johnson Is Dead', '90 min', 'As her father nears the end of his life, filmmaker Kirsten Johnson stages his death in inventive and comical ways to help them both face the inevitable.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s2', 'TV-MA', 'TV Show', 'Blood and Water', '2 Seasons', 'After crossing paths at a party, a Cape Town teen sets out to prove whether a private-school swimming star is her sister who was abducted at birth.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s3', 'TV-MA', 'TV Show', 'Ganglands', '1 Season', 'To protect his family from a powerful drug lord, skilled thief Mehdi and his expert team of robbers are pulled into a violent and deadly turf war.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s4', 'TV-MA', 'TV Show', 'Jailbirds New Orleans', '1 Season', 'Feuds, flirtations and toilet talk go down among the incarcerated women at the Orleans Justice Center in New Orleans on this gritty reality series.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s5', 'TV-MA', 'TV Show', 'Kota Factory', '2 Seasons', 'In a city of coaching centers known to train Indias finest collegiate minds, an earnest but unexceptional student and his friends navigate campus life.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s6', 'TV-MA', 'TV Show', 'Midnight Mass', '1 Season', 'The arrival of a charismatic young priest brings glorious miracles, ominous mysteries and renewed religious fervor to a dying town desperate to believe.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s7', 'PG', 'Movie', 'My Little Pony: A New Generation', '91 min', 'Equestria''s divided. But a bright-eyed hero believes Earth Ponies, Pegasi and Unicorns should be pals  and, hoof to heart, shes determined to prove it.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s8', 'TV-MA', 'Movie', 'Sankofa', '125 min', 'On a photo shoot in Ghana, an American model slips back in time, becomes enslaved on a plantation and bears witness to the agony of her ancestral past.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s9', 'TV-14', 'TV Show', 'The Great British Baking Show', '9 Seasons', 'A talented batch of amateur bakers face off in a 10-week competition, whipping up their best dishes in the hopes of being named the U.K.''s best.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s10', 'PG-13', 'Movie', 'The Starling', '104 min', 'A woman adjusting to life after a loss contends with a feisty bird that''s taken over her garden  and a husband who''s struggling to find a way forward.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s11', 'TV-MA', 'TV Show', 'Vendetta: Truth, Lies and The Mafia', '1 Season', 'Sicily boasts a bold "Anti-Mafia" coalition. But what happens when those trying to bring down organized crime are accused of being criminals themselves?');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s12', 'TV-MA', 'TV Show', 'Bangkok Breaking', '1 Season', 'Struggling to earn a living in Bangkok, a man joins an emergency rescue service and realizes he must unravel a citywide conspiracy.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s13', 'TV-MA', 'Movie', 'Je Suis Karl', '127 min', 'After most of her family is murdered in a terrorist bombing, a young woman is unknowingly lured into joining the very group that killed them.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s14', 'TV-PG', 'Movie', 'Confessions of an Invisible Girl', '91 min', 'When the clever but socially-awkward Tete joins a new school, she''ll do anything to fit in. But the queen bee among her classmates has other ideas.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s15', 'TV-MA', 'TV Show', 'Crime Stories: India Detectives', '1 Season', 'Cameras following Bengaluru police on the job offer a rare glimpse into the complex and challenging inner workings of four major crime investigations.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s16', 'TV-MA', 'TV Show', 'Dear White People', '4 Seasons', 'Students of color navigate the daily slights and slippery politics of life at an Ivy League college that''s not nearly as "post-racial" as it thinks.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s17', 'TV-MA', 'Movie', 'Europe''s Most Dangerous Man: Otto Skorzeny in Spain', '67 min', 'Declassified documents reveal the post-WWII life of Otto Skorzeny, a close Hitler ally who escaped to Spain and became an adviser to world presidents.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s18', 'TV-MA', 'TV Show', 'Falsa identidad', '2 Seasons', 'Strangers Diego and Isabel flee their home in Mexico and pretend to be a married couple to escape his drug-dealing enemies and her abusive husband.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s19', 'TV-14', 'Movie', 'Intrusion', '94 min', 'After a deadly home invasion at a couples new dream house, the traumatized wife searches for answers  and learns the real danger is just beginning.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s20', 'TV-MA', 'TV Show', 'Jaguar', '1 Season', 'In the 1960s, a Holocaust survivor joins a group of self-trained spies who seek justice against Nazis fleeing to Spain to hide after WWII.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s21', 'TV-14', 'TV Show', 'Monsters Inside: The 24 Faces of Billy Milligan', '1 Season', 'In the late 1970s, an accused serial rapist claims multiple personalities control his behavior, setting off a legal odyssey that captivates America.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s22', 'TV-14', 'TV Show', 'Resurrection: Ertugrul', '5 Seasons', 'When a good deed unwittingly endangers his clan, a 13th-century Turkish warrior agrees to fight a sultan''s enemies in exchange for new tribal land.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s23', 'TV-PG', 'Movie', 'Avvai Shanmughi', '161 min', 'Newly divorced and denied visitation rights with his daughter, a doting father disguises himself as a gray-haired nanny in order to spend time with her.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s24', 'TV-Y', 'Movie', 'Go! Go! Cory Carson: Chrissy Takes the Wheel', '61 min', 'From arcade games to sled days and hiccup cures, Cory Carsons curious little sister Chrissy speeds off on her own for fun and adventure all over town!');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s25', 'TV-14', 'Movie', 'Jeans', '166 min', 'When the father of the man she loves insists that his twin sons marry twin sisters, a woman creates an alter ego that might be a bit too convincing.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s26', 'TV-14', 'TV Show', 'Love on the Spectrum', '2 Seasons', 'Finding love can be hard for anyone. For young adults on the autism spectrum, exploring the unpredictable world of dating is even more complicated.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s27', 'TV-PG', 'Movie', 'Minsara Kanavu', '147 min', 'A tangled love triangle ensues when a man falls for a woman studying to become a nun  and she falls for the friend he enlists to help him pursue her.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s28', 'PG-13', 'Movie', 'Grown Ups', '103 min', 'Mourning the loss of their beloved junior high basketball coach, five middle-aged pals reunite at a lake house and rediscover the joys of being a kid.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s29', 'PG-13', 'Movie', 'Dark Skies', '97 min', 'A familys idyllic suburban life shatters when an alien force invades their home, and as they struggle to convince others of the deadly threat.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s30', 'PG-13', 'Movie', 'Paranoia', '106 min', 'Blackmailed by his company''s CEO, a low-level employee finds himself forced to spy on the boss''s rival and former mentor.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s31', 'TV-14', 'Movie', 'Ankahi Kahaniya', '111 min', 'As big city life buzzes around them, lonely souls discover surprising sources of connection and companionship in three tales of love, loss and longing.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s32', 'TV-MA', 'TV Show', 'Chicago Party Aunt', '1 Season', 'Chicago Party Aunt Diane is an idolized troublemaker with a talent for avoiding adulthood  and a soft spot for her soul-searching nephew.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s33', 'TV-MA', 'TV Show', 'Sex Education', '3 Seasons', 'Insecure Otis has all the answers when it comes to sex advice, thanks to his therapist mom. So rebel Maeve proposes a school sex-therapy clinic.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s34', 'TV-MA', 'TV Show', 'Squid Game', '1 Season', 'Hundreds of cash-strapped players accept a strange invitation to compete in children''s games. Inside, a tempting prize awaits  with deadly high stakes.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s35', 'TV-Y7', 'TV Show', 'Tayo and Little Wizards', '1 Season', 'Tayo speeds into an adventure when his friends get kidnapped by evil magicians invading their city in search of a magical gemstone.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s36', 'TV-MA', 'Movie', 'The Father Who Moves Mountains', '110 min', 'When his son goes missing during a snowy hike in the mountains, a retired intelligence officer will stop at nothing  and risk everything  to find him.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s37', 'TV-MA', 'Movie', 'The Stronghold', '105 min', 'Tired of the small-time grind, three Marseille cops get a chance to bust a major drug network. But lines blur when a key informant makes a big ask.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s38', 'TV-Y7', 'TV Show', 'Angry Birds', '1 Season', 'Birds Red, Chuck and their feathered friends have lots of adventures while guarding eggs in their nest that pesky pigs keep trying to steal.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s39', 'PG-13', 'Movie', 'Birth of the Dragon', '96 min', 'A young Bruce Lee angers kung fu traditionalists by teaching outsiders, leading to a showdown with a Shaolin master in this film based on real events.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s40', 'TV-Y7', 'TV Show', 'Chhota Bheem', '3 Seasons', 'A brave, energetic little boy with superhuman powers leads his friends on exciting adventures to guard their fellow Dholakpur villagers from evil.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s41', 'TV-Y7', 'TV Show', 'He-Man and the Masters of the Universe', '1 Season', 'Mighty teen Adam and his heroic squad of misfits discover the legendary power of Grayskull  and their destiny to defend Eternia from sinister Skeletor.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s42', 'PG', 'Movie', 'Jaws', '124 min', 'When an insatiable great white shark terrorizes Amity Island, a police chief, an oceanographer and a grizzled shark hunter seek to destroy the beast.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s43', 'PG', 'Movie', 'Jaws 2', '116 min', 'Four years after the last deadly shark attacks, police chief Martin Brody fights to protect Amity Island from another killer great white.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s44', 'PG', 'Movie', 'Jaws 3', '98 min', 'After the staff of a marine theme park try to capture a young great white shark, they discover its mother has invaded the enclosure and is out for blood.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s45', 'PG-13', 'Movie', 'Jaws: The Revenge', '91 min', 'After another deadly shark attack, Ellen Brody has had enough of Amity Island and moves to the Caribbean  but a great white shark follows her there.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s46', 'PG', 'Movie', 'My Heroes Were Cowboys', '23 min', 'Robin Wiltshire''s painful childhood was rescued by Westerns. Now he lives on the frontier of his dreams, training the horses he loves for the big screen.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s47', 'R', 'Movie', 'Safe House', '115 min', 'Young CIA operative Matt Weston must get a dangerous criminal out of an agency safe house that''s come under attack and get him to a securer location.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s48', 'TV-MA', 'TV Show', 'The Smart Money Woman', '1 Season', 'Five glamorous millennials strive for success as they juggle careers, finances, love and friendships. Based on Arese Ugwu''s 2016 best-selling novel.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s49', 'R', 'Movie', 'Training Day', '122 min', 'A rookie cop with one day to prove himself to a veteran LAPD narcotics officer receives a crash course in his mentor''s questionable brand of justice.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s50', 'TV-MA', 'TV Show', 'Castle and Castle', '2 Seasons', 'A pair of high-powered, successful lawyers find themselves defending opposite interests of the justice system, causing a strain on their happy marriage.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s51', 'TV-PG', 'TV Show', 'Dharmakshetra', '1 Season', 'After the ancient Great War, the god Chitragupta oversees a trial to determine who were the battle''s true heroes and villains.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s52', 'TV-14', 'Movie', 'InuYasha the Movie 2: The Castle Beyond the Looking Glass', '99 min', 'With their biggest foe seemingly defeated, InuYasha and his friends return to everyday life. But the peace is soon shattered by an emerging new enemy.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s53', 'TV-14', 'Movie', 'InuYasha the Movie 3: Swords of an Honorable Ruler', '99 min', 'The Great Dog Demon beaqueathed one of the Three Swords of the Fang to each of his two sons. Now the evil power of the third sword has been awakened.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s54', 'TV-PG', 'Movie', 'InuYasha the Movie 4: Fire on the Mystic Island', '88 min', 'Ai, a young half-demon who has escaped from Horai Island to try to help her people, returns with potential saviors InuYasha, Sesshomaru and Kikyo.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s55', 'TV-PG', 'Movie', 'InuYasha the Movie: Affections Touching Across Time', '100 min', 'A powerful demon has been sealed away for 200 years. But when the demon''s son is awakened, the fate of the world is in jeopardy.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s56', 'TV-PG', 'TV Show', 'Nailed It', '6 Seasons', 'Home bakers with a terrible track record take a crack at re-creating edible masterpieces for a $10,000 prize. It''s part reality contest, part hot mess.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s57', 'TV-14', 'Movie', 'Naruto Shippuden the Movie: Blood Prison', '102 min', 'Mistakenly accused of an attack on the Fourth Raikage, ninja Naruto is imprisoned in the impenetrable Hozuki Castle and his powers are sealed.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s58', 'TV-PG', 'Movie', 'Naruto Shippuden the Movie: Bonds', '93 min', 'When strange ninjas ambush the village of Konohagakure, it''s up to adolescent ninja Naruto and his long-missing pal, Sasuke, to save the planet.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
