INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s66', 'TV-Y', 'TV Show', 'Numberblocks', '6 Seasons', 'In a place called Numberland, math adds up to tons of fun when a group of cheerful blocks work, play and sing together.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s67', 'TV-G', 'TV Show', 'Raja Rasoi Aur Anya Kahaniyan', '1 Season', 'Explore the history and flavors of regional Indian cuisine, from traditional Kashmiri feasts to the vegetarian dishes of Gujarat.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s68', 'TV-PG', 'TV Show', 'Saved by the Bell', '9 Seasons', 'From middle school to college, best friends Zack, Kelly, Slater, Jessie, Screech and Lisa take on the highs and lows of life together in this hit series.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s69', 'TV-14', 'Movie', 'Schumacher', '113 min', 'Through exclusive interviews and archival footage, this documentary traces an intimate portrait of seven-time Formula 1 champion Michael Schumacher.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s70', 'TV-PG', 'TV Show', 'Stories by Rabindranath Tagore', '1 Season', 'The writings of Nobel Prize winner Rabindranath Tagore come to life in this collection of tales set in early-20th-century Bengal.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s71', 'TV-MA', 'TV Show', 'Too Hot To Handle: Latino', '1 Season', 'On this reality show, singles from Latin America and Spain are challenged to give up sex. But here, abstinence comes with a silver lining: US$100,000.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s72', 'TV-Y', 'Movie', 'A StoryBots Space Adventure', '13 min', 'Join the StoryBots and the space travelers of the historic Inspiration4 mission as they search for answers to kids'' questions about space.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s73', 'TV-MA', 'TV Show', 'Jack Whitehall: Travels with My Father', '5 Seasons', 'Jovial comic Jack Whitehall invites his stuffy father, Michael, to travel with him through Southeast Asia in an attempt to strengthen their bond.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s74', 'TV-MA', 'Movie', 'King of Boys', '182 min', 'When a powerful businesswomans political ambitions are threatened by her underworld connections, the ensuing power struggle could cost her everything.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s75', 'TV-PG', 'TV Show', 'The World''s Most Amazing Vacation Rentals', '2 Seasons', 'With an eye for every budget, three travelers visit vacation rentals around the globe and share their expert tips and tricks in this reality series.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s76', 'TV-G', 'Movie', 'You vs. Wild: Out Cold', '106 min', 'After a plane crash leaves Bear with amnesia, he must make choices to save the missing pilot and survive in this high-stakes interactive adventure.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s77', 'TV-14', 'TV Show', 'Yowamushi Pedal', '1 Season', 'A timid, anime-loving teen gets drawn into a school cycling club, where his new friends help him face tough challenges to develop his racing talent.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s78', 'TV-Y7', 'Movie', 'Little Singham - Black Shadow', '48 min', 'Kid cop Little Singham loses all his superpowers while trying to stop the demon Kaals new evil plans! Can his inner strength help him defeat the enemy?');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s79', 'TV-14', 'Movie', 'Tughlaq Durbar', '145 min', 'A budding politician has devious plans to rise in the ranks  until an unexpected new presence begins to interfere with his every crooked move.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s80', 'TV-14', 'Movie', 'Tughlaq Durbar (Telugu)', '145 min', 'A budding politician has devious plans to rise in the ranks  until an unexpected new presence begins to interfere with his every crooked move.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s81', 'TV-Y7', 'Movie', 'Firedrake the Silver Dragon', '93 min', 'When his home is threatened by humans, a young dragon summons the courage to seek a mythical paradise where dragons can live in peace and fly free.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s82', 'R', 'Movie', 'Kate', '106 min', 'Slipped a fatal poison on her final job, a ruthless assassin working in Tokyo has less than 24 hours to find out who ordered the hit and exact revenge.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s83', 'TV-14', 'TV Show', 'Lucifer', '6 Seasons', 'Bored with being the Lord of Hell, the devil relocates to Los Angeles, where he opens a nightclub and forms a connection with a homicide detective.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s84', 'TV-MA', 'TV Show', 'Metal Shop Masters', '1 Season', 'On this competition show, a group of metal artists torch, cut and weld epic, badass creations from hardened steel. Only one will win a $50,000 prize.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
