INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s97', 'TV-MA', 'Movie', 'If I Leave Here Tomorrow: A Film About Lynyrd Skynyrd', '97 min', 'Using interviews and archival footage, this documentary charts the story of the legendary Southern rockers with a focus on front man Ronnie Van Zant.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s98', 'TV-Y7', 'TV Show', 'Kid Cosmic', '2 Seasons', 'A boy''s superhero dreams come true when he finds five powerful cosmic stones. But saving the day is harder than he imagined  and he can''t do it alone.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s99', 'TV-Y', 'TV Show', 'Octonauts: Above and Beyond', '1 Season', 'The Octonauts expand their exploration beyond the sea  and onto land! With new rides and new friends, they''ll protect any habitats and animals at risk.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s100', 'TV-MA', 'TV Show', 'On the Verge', '1 Season', 'Four women  a chef, a single mom, an heiress and a job seeker  dig into love and work, with a generous side of midlife crises, in pre-pandemic LA.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s101', 'TV-Y7', 'TV Show', 'Tobot Galaxy Detectives', '2 Seasons', 'An intergalactic device transforms toy cars into robots: the Tobots! Working with friends to solve mysteries, they protect the world from evil.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s102', 'TV-MA', 'Movie', 'Untold: Breaking Point', '80 min', 'Under pressure to continue a winning tradition in American tennis, Mardy Fish faced mental health challenges that changed his life on and off the court.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s103', 'TV-14', 'TV Show', 'Countdown: Inspiration4 Mission to Space', '1 Season', 'From training to launch to landing, this all-access docuseries rides along with the Inspiration4 crew on the first all-civilian orbital space mission.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s104', 'TV-MA', 'Movie', 'Shadow Parties', '117 min', 'A family faces destruction in a long-running conflict between communities that pits relatives against each other amid attacks and reprisals.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s105', 'TV-Y', 'TV Show', 'Tayo the Little Bus', '2 Seasons', 'As they learn their routes around the busy city, Tayo and his little bus friends discover new sights and go on exciting adventures every day.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s106', 'TV-14', 'Movie', 'Angamaly Diaries', '128 min', 'After growing up amidst the gang wars of his hometown, Vincent forms an entrepreneurial squad of his own and ends up on the wrong side of the law.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s107', 'TV-G', 'TV Show', 'Bunk''d', '5 Seasons', 'The Ross siblings of Disney''s hit series "Jessie" spend a summer full of fun and adventure at Maine''s Camp Kikiwaka, where their parents first met.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s108', 'G', 'Movie', 'A Champion Heart', '90 min', 'When a grieving teen must work off her debt to a ranch, she cares for a wounded horse that teaches her more about healing than she expected.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s109', 'TV-G', 'TV Show', 'Dive Club', '1 Season', 'On the shores of Cape Mercy, a skillful group of teen divers investigate a series of secrets and signs after one of their own mysteriously goes missing.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s110', 'TV-MA', 'TV Show', 'La casa de papel', '5 Seasons', 'Eight thieves take hostages and lock themselves in the Royal Mint of Spain as a criminal mastermind manipulates the police to carry out his plan.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s111', 'TV-MA', 'TV Show', 'Money Heist: From Tokyo to Berlin', '1 Season', 'The filmmakers and actors behind "Money Heist" characters like Tokyo and the Professor talk about the emotional artistic process of filming the series.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s112', 'TV-Y', 'TV Show', 'Sharkdog', '1 Season', 'Half shark, half dog with a big heart and a belly full of fish sticks! Together, Sharkdog and his human pal Max can take on any silly or messy adventure.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s113', 'PG-13', 'Movie', 'Worth', '119 min', 'In the wake of the Sept. 11 attacks, a lawyer faces an emotional reckoning as he attempts to put a dollar value on the lives lost. Based on real events.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s114', 'TV-PG', 'Movie', 'Afterlife of the Party', '110 min', 'Cassie lives to party... until she dies in a freak accident. Now this social butterfly needs to right her wrongs on Earth if she wants to earn her wings.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s115', 'TV-14', 'Movie', 'Anjaam', '143 min', 'A wealthy industrialists dangerous obsession with a flight attendant destroys her world, until she takes matters into her own hands to exact revenge.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s116', 'PG', 'Movie', 'Bright Star', '119 min', 'This drama details the passionate three-year romance between Romantic poet John Keats  who died tragically at age 25  and his great love and muse.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
