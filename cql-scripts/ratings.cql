INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s140', 'R', 'Movie', 'Do the Right Thing', '120 min', 'On a sweltering day in Brooklyn, simmering racial tensions between residents rise to the surface and ignite rage, violence and tragedy.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
