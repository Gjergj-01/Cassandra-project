INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s60', 'TV-PG', 'Movie', 'Naruto Shippuden: The Movie', '95 min', 'The adventures of adolescent ninja Naruto Uzumaki continue as he''s tasked with protecting a priestess from a demon  but to do so, he must die.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
