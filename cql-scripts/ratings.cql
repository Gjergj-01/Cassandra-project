INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s95', 'PG', 'Movie', 'Show Dogs', '90 min', 'A rough and tough police dog must go undercover with an FBI agent as a prim and proper pet at a dog show to save a baby panda from an illegal sale.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
