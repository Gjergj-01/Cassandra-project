INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s138', 'PG', 'Movie', 'Crocodile Dundee in Los Angeles', '95 min', 'When Mick "Crocodile" Dundee and his family land in Los Angeles, they soon learn some lessons about American life in this comedy sequel.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
