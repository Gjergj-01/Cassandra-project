INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s524', 'TV-MA', 'TV Show', 'Marcella', '3 Seasons', 'Her marriage just ended and she''s returning to work as a London detective after 12 years away. Is the serial killer she once investigated back, too?');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
