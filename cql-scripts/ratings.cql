INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s125', 'TV-Y7', 'TV Show', 'Pororo - The Little Penguin', '3 Seasons', 'On a tiny island, Pororo the penguin has fun adventures with his friends Eddy the fox, Loopy the beaver, Poby the polar bear and Crong the dinosaur.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s126', 'TV-MA', 'TV Show', 'Q-Force', '1 Season', 'A gay superspy and his scrappy LGBTQ squad fight to prove themselves to the agency that underestimated them. Today, West Hollywood... tomorrow, the world!');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s127', 'TV-14', 'Movie', 'Shikara', '115 min', 'A couple must strive to remain resilient after regional hostilities drive them from their beloved home into a refugee camp.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s128', 'PG', 'Movie', 'A Cinderella Story', '95 min', 'Teen Sam meets the boy of her dreams at a dance before returning to toil in her stepmother''s diner. Can her lost cell phone bring them together?');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s129', 'PG-13', 'Movie', 'Agatha Christie''s Crooked House', '115 min', 'When a detective investigates the death of his ex-lover''s grandfather, he uncovers secrets about the tycoon''s manipulative family.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
