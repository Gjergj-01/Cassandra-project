INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s87', 'TV-MA', 'Movie', 'Prey', '87 min', 'A hiking trip into the wild turns into a desperate bid for survival for five friends on the run from a mysterious shooter.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s88', 'TV-Y', 'TV Show', 'Titipo Titipo', '2 Seasons', 'Titipo the train is out to prove that he''s got what it takes to help the folks of Train Village ride the rails safely and reliably.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s89', 'PG-13', 'Movie', 'Blood Brothers: Malcolm X and Muhammad Ali', '96 min', 'From a chance meeting to a tragic fallout, Malcolm X and Muhammad Ali''s extraordinary bond cracks under the weight of distrust and shifting ideals.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s90', 'TV-Y7', 'TV Show', 'Mighty Raju', '4 Seasons', 'Born with superhuman abilities, young Raju wants to use his powers to make the world a better place  but that will mean facing plenty of challenges!');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s91', 'TV-MA', 'Movie', 'Paradise Hills', '95 min', 'Uma wakes up in a lush tropical facility designed to turn willful girls into perfect ladies. Thats bad enough, but its real purpose is even worse.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s92', 'TV-14', 'Movie', 'The Women and the Murderer', '92 min', 'This documentary traces the capture of serial killer Guy Georges through the tireless work of two women: a police chief and a victim''s mother.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s93', 'TV-MA', 'TV Show', 'Into the Night', '2 Seasons', 'Passengers and crew aboard a hijacked overnight flight scramble to outrace the sun as a mysterious cosmic event wreaks havoc on the world below.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
