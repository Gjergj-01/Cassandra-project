INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
VALUES ('s123', 'R', 'Movie', 'In the Cut', '118 min', 'After embarking on an affair with the cop probing the murder of a young woman, an insular schoolteacher suspects her lover was involved in the crime.');
INSERT INTO movies.ratings (show_id, rating, type, title, duration, description)
